 "page_data_script": "data.posts = [{'title': 'The quiet comeback of server-rendered HTML', 'excerpt': 'After a decade of client-side everything, the pendulum is swinging back — and the web feels faster for it.', 'category': 'Engineering', 'author': 'Dana Whitman', 'date': 'Jun 2, 2026', 'read': '8 min', 'image': 'https://images.unsplash.com/photo-1517180102446-f3ece451e9d8?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}, {'title': 'Designing for the first five seconds', 'excerpt': \"What a reader decides before they've read a word, and how to earn the next click.\", 'category': 'Design', 'author': 'Marcus Lee', 'date': 'May 28, 2026', 'read': '6 min', 'image': 'https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}, {'title': 'The economics of a one-person newsroom', 'excerpt': 'A year of running an independent publication, with the real numbers attached.', 'category': 'Media', 'author': 'Priya Anand', 'date': 'May 21, 2026', 'read': '11 min', 'image': 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}, {'title': 'Why your type scale is fighting you', 'excerpt': 'Most sites pick font sizes by feel. A little math makes everything click.', 'category': 'Design', 'author': 'Marcus Lee', 'date': 'May 14, 2026', 'read': '5 min', 'image': 'https://images.unsplash.com/photo-1488972685288-c3fd157d7c7a?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}, {'title': 'Notes on writing in public', 'excerpt': 'Publishing rough ideas is terrifying and, it turns out, the whole point.', 'category': 'Culture', 'author': 'Dana Whitman', 'date': 'May 7, 2026', 'read': '7 min', 'image': 'https://images.unsplash.com/photo-1455390582262-044cdead5f82?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}, {'title': 'The interface is the product now', 'excerpt': 'When every company ships the same models, the wrapper is the moat.', 'category': 'Engineering', 'author': 'Priya Anand', 'date': 'Apr 30, 2026', 'read': '9 min', 'image': 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?auto=format&fit=crop&q=80&w=1100', 'url': '/article'}]",
