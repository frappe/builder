         "blockName": "Article Prose",
         "children": [
          {
           "attributes": {},
           "baseStyles": {
            "color": "var(--84e90ee1-4a77-4d27-a1d7-1b461d01a359, #16161A)",
            "fontFamily": "Newsreader",
            "fontSize": "22px",
            "height": "fit-content",
