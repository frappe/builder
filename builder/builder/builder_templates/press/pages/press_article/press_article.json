           "tabletStyles": {}
          },
          {
           "attributes": {},
           "baseStyles": {
            "color": "var(--8d4049dc-1ae6-4232-8759-f39670771fa4, #6B6B73)",
            "fontFamily": "Inter",
            "fontSize": "18px",
            "height": "fit-content",
            "lineHeight": "1.8",
            "marginBottom": "24px",
            "minWidth": "10px",
            "width": "fit-content"
           },
           "blockId": "28e0df9cfd",
           "blockName": "Prose Paragraph",
           "children": [],
           "classes": [],
           "customAttributes": {},
           "element": "p",
           "innerHTML": "None of this means the single-page app is dead. It means we finally have a spectrum instead of a default — and that's the healthiest the web platform has felt in a long time.",
