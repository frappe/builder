            "marginBottom": "24px",
            "minWidth": "10px",
            "width": "fit-content"
           },
           "blockId": "7ded357fdd",
           "blockName": "Prose Paragraph",
           "children": [],
           "classes": [],
           "customAttributes": {},
           "element": "p",
           "innerHTML": "For ten years the answer to every front-end question was \"add more JavaScript.\" We shipped frameworks to render frameworks. Somewhere along the way, the document got lost.",
           "mobileStyles": {},
           "rawStyles": {},
           "tabletStyles": {}
          },
          {
           "attributes": {},
           "baseStyles": {
            "color": "var(--8d4049dc-1ae6-4232-8759-f39670771fa4, #6B6B73)",
            "fontFamily": "Inter",
            "fontSize": "18px",
            "height": "fit-content",
            "lineHeight": "1.8",
            "marginBottom": "24px",
            "minWidth": "10px",
            "width": "fit-content"
           },
           "blockId": "ac6529c382",
           "blockName": "Prose Paragraph",
           "children": [],
           "classes": [],
           "customAttributes": {},
           "element": "p",
           "innerHTML": "The return to server-rendered HTML isn't nostalgia. It's a recognition that the browser is very, very good at rendering documents, and that most of what we build is, underneath the chrome, a document.",
           "mobileStyles": {},
           "rawStyles": {},
           "tabletStyles": {}
          },
          {
           "attributes": {},
           "baseStyles": {
            "color": "var(--84e90ee1-4a77-4d27-a1d7-1b461d01a359, #16161A)",
            "fontFamily": "Newsreader",
            "fontSize": "30px",
            "fontWeight": "500",
            "height": "fit-content",
            "lineHeight": "1.4",
            "marginBottom": "16px",
            "marginTop": "16px",
            "minWidth": "10px",
            "width": "fit-content"
           },
           "blockId": "6be833155b",
           "blockName": "Prose H2",
           "children": [],
           "classes": [],
           "customAttributes": {},
           "element": "h2",
           "innerHTML": "What changed",
           "mobileStyles": {},
           "rawStyles": {},
           "tabletStyles": {}
          },
          {
           "attributes": {},
           "baseStyles": {
            "color": "var(--8d4049dc-1ae6-4232-8759-f39670771fa4, #6B6B73)",
            "fontFamily": "Inter",
            "fontSize": "18px",
            "height": "fit-content",
            "lineHeight": "1.8",
            "marginBottom": "24px",
            "minWidth": "10px",
            "width": "fit-content"
           },
           "blockId": "a4e4bc1ff5",
           "blockName": "Prose Paragraph",
           "children": [],
           "classes": [],
           "customAttributes": {},
           "element": "p",
           "innerHTML": "Three things, mostly. Streaming made server rendering feel instant. Islands let us sprinkle interactivity without shipping the whole app. And a generation of developers got tired of debugging hydration mismatches at midnight.",
           "mobileStyles": {},
           "rawStyles": {},
           "tabletStyles": {}
          },
          {
           "attributes": {},
           "baseStyles": {
            "borderLeftColor": "var(--4b3b4a52-d650-4def-a4d8-5e5caa6bd05f, #B23A2E)",
            "borderLeftStyle": "solid",
            "borderLeftWidth": "3px",
            "display": "flex",
            "flexDirection": "column",
            "flexShrink": 0,
            "marginBottom": "32px",
            "marginTop": "8px",
            "overflow": "hidden",
            "paddingLeft": "24px"
           },
           "blockId": "02d32036ea",
           "blockName": "Pull Quote",
           "children": [
            {
             "attributes": {},
             "baseStyles": {
              "color": "var(--84e90ee1-4a77-4d27-a1d7-1b461d01a359, #16161A)",
              "fontFamily": "Newsreader",
              "fontSize": "26px",
              "fontWeight": "500",
              "height": "fit-content",
              "lineHeight": "1.35",
              "minWidth": "10px",
              "width": "fit-content"
             },
             "blockId": "b541279ffd",
             "blockName": "Pull Quote Text",
             "children": [],
             "classes": [],
             "customAttributes": {},
             "element": "p",
             "innerHTML": "The best framework is the one your users never have to download.",
             "mobileStyles": {},
             "rawStyles": {},
             "tabletStyles": {}
            }
           ],
           "classes": [],
           "customAttributes": {},
           "element": "div",
           "mobileStyles": {},
