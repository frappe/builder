             },
             "blockId": "7b01a88495",
             "blockName": "About Text 2",
             "children": [],
             "classes": [],
             "customAttributes": {},
             "element": "p",
             "innerHTML": "I care about craft, clear writing, and shipping. I sketch on paper, prototype in Figma, and build in Vue — which means the thing I hand off is the thing that ships.",
             "mobileStyles": {},
             "rawStyles": {},
             "tabletStyles": {}
            },
            {
             "attributes": {},
